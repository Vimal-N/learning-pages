---
layout: base.njk
---
{% block head %}
<style>
body { overflow-y: auto; }
body::before { opacity: 0.35; }

/* ─── Breadcrumb ─── */
.breadcrumb { max-width: 880px; margin: 0 auto; padding: 24px 32px 0; }
.breadcrumb a, .breadcrumb span { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; text-decoration: none; letter-spacing: 0.5px; }
.breadcrumb a { color: var(--text-dim); transition: color 0.2s; }
.breadcrumb a:hover { color: var(--accent); }
.breadcrumb .sep { color: var(--border); margin: 0 8px; }
.breadcrumb .current { color: var(--text-muted); }

/* ─── Topic Hero ─── */
.topic-hero { max-width: 880px; margin: 0 auto; padding: 36px 32px 40px; }
.topic-hero .session-badge { margin-bottom: 16px; }
.topic-hero h1 { font-size: 2.8rem; margin-bottom: 12px; }
.topic-hero h1 em { font-style: normal; color: var(--accent); }
.topic-hero-sub { font-size: 1.05rem; color: var(--text-secondary); max-width: 620px; line-height: 1.7; font-weight: 300; }

.topic-stats { display: flex; gap: 36px; margin-top: 28px; }
.topic-stat { text-align: center; }
.topic-stat-num { font-family: 'Source Serif 4', serif; font-size: 1.6rem; font-weight: 700; color: var(--text-primary); }
.topic-stat-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-top: 2px; }

/* ─── Phase Sections ─── */
.phases-container { max-width: 880px; margin: 0 auto; padding: 0 32px 100px; }
.phase-block { margin-bottom: 40px; }

.phase-header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
.phase-num { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--accent); background: var(--accent-soft); padding: 4px 10px; border-radius: 4px; flex-shrink: 0; }
.phase-title { font-family: 'Source Serif 4', serif; font-size: 1.2rem; font-weight: 600; color: var(--text-primary); }

.session-grid { display: grid; gap: 8px; }

.session-link { display: grid; grid-template-columns: 44px 1fr auto; align-items: center; gap: 16px; padding: 14px 18px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); text-decoration: none; transition: all 0.25s; cursor: pointer; }
.session-link:hover { border-color: var(--accent); transform: translateX(4px); background: var(--bg-hover); }
.session-link.available { border-left: 3px solid var(--accent); }
.session-link.upcoming { opacity: 0.5; cursor: default; }
.session-link.upcoming:hover { border-color: var(--border); transform: none; background: var(--bg-card); }

.s-num { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; font-weight: 700; color: var(--text-dim); text-align: center; }
.session-link.available .s-num { color: var(--accent); }

.s-title { font-size: 0.92rem; font-weight: 500; color: var(--text-primary); }
.session-link.upcoming .s-title { color: var(--text-muted); }

.s-status { font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 3px 9px; border-radius: 4px; }
.s-status.live { background: var(--green-soft); color: var(--green); }
.s-status.soon { background: var(--bg-elevated); color: var(--text-dim); }

/* ─── Footer ─── */
.site-footer { border-top: 1px solid var(--border); padding: 28px 32px; text-align: center; }
.site-footer p { font-size: 0.78rem; color: var(--text-dim); }

/* ─── Stagger ─── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}
.phase-block { animation: fadeInUp 0.5s ease both; }
.phase-block:nth-child(1) { animation-delay: 0.1s; }
.phase-block:nth-child(2) { animation-delay: 0.18s; }
.phase-block:nth-child(3) { animation-delay: 0.26s; }
.phase-block:nth-child(4) { animation-delay: 0.34s; }
.phase-block:nth-child(5) { animation-delay: 0.42s; }
</style>
{% endblock %}


{{ content | safe }}
