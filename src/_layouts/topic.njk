---
layout: base.njk
---
{% block head %}
<style>
body { overflow-y: auto; }
body::before { opacity: 0.35; }

/* ─── Breadcrumb ─── */
.breadcrumb { max-width: 880px; margin: 0 auto; padding: 24px 32px 0; }
.breadcrumb a, .breadcrumb span { font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; text-decoration: none; letter-spacing: 0.5px; }
.breadcrumb a { color: var(--text-dim); transition: color 0.2s; }
.breadcrumb a:hover { color: var(--accent); }
.breadcrumb .sep { color: var(--border); margin: 0 8px; }
.breadcrumb .current { color: var(--text-muted); }

/* ─── Topic Hero ─── */
.topic-hero { max-width: 880px; margin: 0 auto; padding: 36px 32px 40px; }
.topic-hero .session-badge { margin-bottom: 16px; }
.topic-hero h1 { font-size: 2rem; margin-bottom: 12px; }
.topic-hero h1 em { font-style: normal; color: var(--accent); }
.topic-hero-sub { font-size: 0.9rem; color: var(--text-secondary); max-width: 620px; line-height: 1.7; font-weight: 300; }

.topic-stats { display: flex; gap: 36px; margin-top: 28px; }
.topic-stat { text-align: center; }
.topic-stat-num { font-family: 'Google Sans', sans-serif; font-size: 1.6rem; font-weight: 700; color: var(--text-primary); }
.topic-stat-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); margin-top: 2px; }

/* ─── Phase Sections ─── */
.phases-container { max-width: 880px; margin: 0 auto; padding: 0 32px 100px; }
.phase-block { margin-bottom: 40px; }

.phase-header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
.phase-num { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: var(--accent); background: var(--accent-soft); padding: 4px 10px; border-radius: 4px; flex-shrink: 0; }
.phase-title { font-family: 'Google Sans', sans-serif; font-size: 1.0rem; font-weight: 600; color: var(--text-primary); }

.session-grid { display: grid; gap: 8px; }

.session-link { display: grid; grid-template-columns: 44px 1fr auto; align-items: center; gap: 16px; padding: 14px 18px; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-md); text-decoration: none; cursor: pointer; }
.session-link:hover { background: var(--bg-secondary); }
.session-link.available { border-left: 3px solid var(--accent); }
.session-link.upcoming { opacity: 0.5; cursor: default; }
.session-link.upcoming:hover { border-color: var(--border); transform: none; background: var(--bg-card); }

.s-num { font-family: 'IBM Plex Mono', monospace; font-size: 0.92rem; font-weight: 700; color: var(--text-dim); text-align: center; }
.session-link.available .s-num { color: var(--accent); }

.s-body { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; min-width: 0; }
.s-title { font-size: 0.92rem; font-weight: 500; color: var(--text-primary); }
.session-link.upcoming .s-title { color: var(--text-muted); }

.s-level { display: inline-flex; align-items: center; font-family: 'IBM Plex Mono', monospace; font-size: 0.58rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 2px 7px; border-radius: 3px; flex-shrink: 0; }
.s-level.beginner     { color: var(--green);  background: rgba(46,160,67,0.08); }
.s-level.intermediate { color: #d4640a; background: rgba(212,100,10,0.1); }
.s-level.advanced     { color: #9b59b6;       background: rgba(155,89,182,0.08); }

.s-status { font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; padding: 3px 9px; border-radius: 4px; }
.s-status.live { background: var(--green-soft); color: var(--green); }
.s-status.soon { background: var(--bg-elevated); color: var(--text-dim); }

/* ─── Expanded session card sub-elements ─── */
.session-link { align-items: center; }
.s-body { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
.s-head { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
.s-title { color: var(--text-primary); }
.s-desc { font-size: 0.78rem; color: var(--text-secondary); line-height: 1.5; }
.s-meta { display: flex; flex-direction: row; align-items: center; gap: 6px; flex-shrink: 0; }
.phase-level { display: inline-flex; align-items: center; font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 3px 9px; border-radius: 3px; flex-shrink: 0; }
.phase-level.beginner     { color: var(--green);  background: rgba(46,160,67,0.08); }
.phase-level.intermediate { color: #d4640a; background: rgba(212,100,10,0.1); }
.phase-level.advanced     { color: #9b59b6;        background: rgba(155,89,182,0.08); }
.phase-level + .phase-level { margin-left: 4px; }
.phase-meta { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: var(--text-muted); margin-left: auto; }
.phase-btn { font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; text-decoration: none; padding: 4px 12px; border-radius: 4px; transition: background 0.18s, border-color 0.18s, color 0.18s; white-space: nowrap; }
.phase-btn-slides { background: var(--bg-elevated); color: var(--text-secondary); border: 1px solid var(--border); }
.phase-btn-slides:hover { background: #d0d0d0; border-color: #b0b0b0; color: var(--text-primary); }
.phase-btn-notes  { background: var(--accent-soft); color: var(--accent); border: 1px solid rgba(176,112,32,0.2); }
.phase-btn-notes:hover  { background: rgba(176,112,32,0.25); border-color: rgba(176,112,32,0.5); }

/* ─── Footer ─── */
.site-footer { border-top: 1px solid var(--border); padding: 28px 32px; text-align: center; }
.site-footer p { font-size: 0.78rem; color: var(--text-dim); }

/* ─── Stagger ─── */
@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(14px); }
  to { opacity: 1; transform: translateY(0); }
}
.phase-block { animation: fadeInUp 0.5s ease both; }
.phase-block:nth-child(1) { animation-delay: 0.1s; }
.phase-block:nth-child(2) { animation-delay: 0.18s; }
.phase-block:nth-child(3) { animation-delay: 0.26s; }
.phase-block:nth-child(4) { animation-delay: 0.34s; }
.phase-block:nth-child(5) { animation-delay: 0.42s; }
</style>
{% endblock %}


{{ content | safe }}
