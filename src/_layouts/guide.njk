---
layout: base.njk
---
{% block head %}
<style>
body { overflow: hidden; }

/* ─── Shell ─── */
.guide-shell {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
}

/* ─── Top Bar ─── */
.guide-topbar {
  height: 48px;
  flex-shrink: 0;
  background: var(--bg-secondary);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 14px;
  z-index: 50;
}
.guide-back {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.68rem;
  font-weight: 600;
  color: var(--text-muted);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 5px 10px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-elevated);
  white-space: nowrap;
  transition: color 0.2s, border-color 0.2s;
}
.guide-back:hover { color: var(--accent); border-color: var(--accent); }
.topbar-sep { color: var(--border); flex-shrink: 0; }
.guide-topbar-title {
  font-size: 0.82rem;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}
.guide-topbar-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  color: var(--accent);
  background: var(--accent-soft);
  padding: 3px 9px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}
.guide-type-badge {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--cyan);
  background: var(--cyan-soft);
  border: 1px solid rgba(78,205,196,0.2);
  padding: 3px 9px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}
.sidebar-toggle-btn {
  display: none;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.62rem;
  font-weight: 600;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  padding: 4px 10px;
  border-radius: 5px;
  cursor: pointer;
  white-space: nowrap;
  flex-shrink: 0;
}

/* ─── Body: sidebar + deck ─── */
.guide-body {
  flex: 1;
  display: flex;
  overflow: hidden;
  min-height: 0;
}

/* ─── Sidebar ─── */
.guide-sidebar {
  width: 230px;
  flex-shrink: 0;
  background: var(--bg-secondary);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.sidebar-head {
  padding: 12px 14px 8px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.58rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-dim);
  border-bottom: 1px solid var(--border-subtle);
  flex-shrink: 0;
}
.sidebar-list {
  flex: 1;
  overflow-y: auto;
  padding: 6px 0;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
}
.sidebar-list::-webkit-scrollbar { width: 4px; }
.sidebar-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
.sb-item {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  padding: 8px 12px;
  cursor: pointer;
  border-left: 3px solid transparent;
  transition: background 0.15s, border-color 0.15s;
}
.sb-item:hover { background: var(--bg-elevated); }
.sb-item.is-active { background: var(--bg-elevated); border-left-color: var(--cyan); }
.sb-item.is-done  { border-left-color: var(--green); }
.sb-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--border); flex-shrink: 0; margin-top: 5px;
  transition: background 0.2s;
}
.sb-item.is-done  .sb-dot { background: var(--green); }
.sb-item.is-active .sb-dot { background: var(--cyan); }
.sb-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.58rem; color: var(--text-dim);
  min-width: 18px; flex-shrink: 0; padding-top: 1px;
}
.sb-item.is-active .sb-num { color: var(--cyan); }
.sb-item.is-done   .sb-num { color: var(--green); }
.sb-label {
  font-size: 0.76rem; color: var(--text-muted);
  line-height: 1.35; overflow: hidden;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
}
.sb-item.is-active .sb-label { color: var(--text-primary); font-weight: 500; }
.sb-item.is-done   .sb-label { color: var(--text-secondary); }
.sidebar-foot {
  padding: 10px 14px;
  border-top: 1px solid var(--border-subtle);
  flex-shrink: 0;
}
.prog-track {
  height: 3px; background: var(--border); border-radius: 2px;
  margin-bottom: 6px; overflow: hidden;
}
.prog-fill {
  height: 100%; background: linear-gradient(90deg, var(--cyan), var(--accent));
  border-radius: 2px; transition: width 0.4s ease; width: 0%;
}
.prog-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.58rem; color: var(--text-dim);
}

/* ─── Deck — scrolls vertically, one page at a time ─── */
.guide-deck {
  flex: 1;
  overflow-y: auto;
  scrollbar-width: thin;
  scrollbar-color: var(--border) transparent;
  position: relative;
}
.guide-deck::-webkit-scrollbar { width: 5px; }
.guide-deck::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

/* ─── Slides — paginated, only active is shown ─── */
/* Before JS runs: first slide visible immediately (no flash) */
.slide {
  display: none;
  flex-direction: column;
  min-height: 100%;
  position: relative;
  box-sizing: border-box;
}
.slide:first-child {
  display: flex;
  opacity: 1;
  pointer-events: all;
  transform: translateY(0);
  transition: none;
}
/* Once JS adds .deck-ready, it owns visibility entirely */
.deck-ready .slide {
  display: none;
  opacity: 0;          /* reset V1 styles.css opacity/pointer rules */
  pointer-events: none;
}
.deck-ready .slide.is-active {
  display: flex;
  opacity: 1;          /* override V1 styles.css: .slide { opacity:0 } */
  pointer-events: all; /* override V1 styles.css: .slide { pointer-events:none } */
  transform: translateY(0); /* override V1 styles.css: .slide { transform:translateY(12px) } */
  transition: none;    /* cancel V1's opacity/transform transitions */
}
/* Animation only fires during navigation (JS adds .is-entering) */
.deck-ready .slide.is-entering {
  animation: pageIn 0.38s cubic-bezier(0.22, 1, 0.36, 1);
}
@keyframes pageIn {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Top accent stripe — cycles through design system colours */
.slide::before {
  content: '';
  display: block;
  height: 3px;
  flex-shrink: 0;
}
.slide:nth-child(7n+1)::before { background: var(--accent); }
.slide:nth-child(7n+2)::before { background: var(--blue); }
.slide:nth-child(7n+3)::before { background: var(--purple); }
.slide:nth-child(7n+4)::before { background: var(--cyan); }
.slide:nth-child(7n+5)::before { background: var(--green); }
.slide:nth-child(7n+6)::before { background: #c05010; }
.slide:nth-child(7n+7)::before { background: var(--red); }

.slide { background: var(--bg-primary); }

/* ─── Slide content layout ─── */
.v2-slide-wrap {
  max-width: 820px;
  width: 100%;
  margin: 0 auto;
  padding: 36px 48px 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Section header */
.v2-section-hd {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 22px;
  padding-bottom: 16px;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
  flex-wrap: wrap;
}
.v2-section-num {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-dim);
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  padding: 3px 9px;
  border-radius: 4px;
  white-space: nowrap;
  flex-shrink: 0;
}
.v2-section-title {
  font-family: 'Google Sans', sans-serif;
  font-size: 1.55rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
  margin: 0;
}
.v2-section-title em { font-style: normal; color: var(--accent); }
.v2-section-sub {
  width: 100%;
  font-size: 0.88rem;
  color: var(--text-muted);
  margin: 2px 0 0;
  line-height: 1.6;
  font-weight: 300;
}

/* ─── Page Navigation Bar (injected by JS at bottom of each slide) ─── */
.slide-nav {
  max-width: 820px;
  width: 100%;
  margin: 0 auto;
  padding: 32px 48px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-shrink: 0;
  border-top: 1px solid var(--border-subtle);
  margin-top: 32px;
}
.slide-nav-btn {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 9px 20px;
  border-radius: 6px;
  border: 1px solid var(--border);
  background: var(--bg-elevated);
  color: var(--text-secondary);
  cursor: pointer;
  transition: all 0.18s;
  white-space: nowrap;
}
.slide-nav-btn:hover:not(:disabled) {
  border-color: var(--accent);
  color: var(--accent);
  background: var(--accent-soft);
}
.slide-nav-btn:disabled {
  opacity: 0.25;
  cursor: default;
  pointer-events: none;
}
.slide-nav-btn.next-btn {
  background: var(--accent);
  border-color: var(--accent);
  color: #000;
  font-weight: 800;
}
.slide-nav-btn.next-btn:hover:not(:disabled) {
  opacity: 0.85;
}
.slide-nav-info {
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.62rem;
  color: var(--text-dim);
  letter-spacing: 1px;
  text-align: center;
}

/* ─── Floating section counter ─── */
.guide-float-counter {
  position: fixed;
  bottom: 20px;
  right: 20px;
  font-family: 'IBM Plex Mono', monospace;
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--text-muted);
  background: var(--bg-elevated);
  border: 1px solid var(--border);
  padding: 5px 12px;
  border-radius: 20px;
  z-index: 100;
  pointer-events: none;
}

/* ─── Body text ─── */
.v2-slide-wrap p {
  font-size: 0.93rem; color: var(--text-secondary); line-height: 1.75; margin: 8px 0;
}
.v2-slide-wrap h3 {
  font-family: 'Google Sans', sans-serif; font-size: 1.0rem; font-weight: 600;
  color: var(--text-primary); margin: 22px 0 8px; text-transform: none; letter-spacing: 0;
}
.v2-slide-wrap h4 {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--accent); margin: 16px 0 6px;
}
.v2-slide-wrap ul, .v2-slide-wrap ol { margin: 8px 0; padding-left: 0; list-style: none; }
.v2-slide-wrap li {
  font-size: 0.92rem; color: var(--text-secondary); line-height: 1.65;
  padding: 3px 0 3px 20px; position: relative;
}
.v2-slide-wrap ul > li::before {
  content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.85rem;
}
.v2-slide-wrap ol { counter-reset: ol-counter; }
.v2-slide-wrap ol > li { counter-increment: ol-counter; }
.v2-slide-wrap ol > li::before {
  content: counter(ol-counter) '.'; position: absolute; left: 0;
  font-family: 'IBM Plex Mono', monospace; font-size: 0.7rem; font-weight: 700;
  color: var(--accent); top: 5px;
}
.v2-slide-wrap code {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.84em;
  background: var(--code-bg); border: 1px solid var(--border-subtle);
  padding: 1px 6px; border-radius: 4px; color: var(--text-primary);
}
.v2-slide-wrap strong { font-weight: 600; color: var(--text-primary); }
.v2-slide-wrap table { width: 100%; border-collapse: collapse; margin: 12px 0; font-size: 0.87rem; }
.v2-slide-wrap th {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim);
  padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border);
  background: var(--bg-elevated);
}
.v2-slide-wrap td {
  padding: 8px 12px; color: var(--text-secondary); border-bottom: 1px solid var(--border-subtle);
  line-height: 1.5; vertical-align: top;
}
.v2-slide-wrap tr:last-child td { border-bottom: none; }

/* ─── V2 Components ─── */
.kbd {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.8em;
  background: var(--bg-elevated); border: 1px solid var(--border);
  border-bottom: 2px solid var(--border); padding: 1px 6px;
  border-radius: 4px; color: var(--text-primary); white-space: nowrap;
}
.v2-version-stamp {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: var(--text-dim);
  padding: 5px 0 14px; letter-spacing: 0.5px;
}
.v2-quickstart {
  display: flex; gap: 14px; align-items: flex-start;
  background: var(--cyan-soft); border: 1px solid rgba(78,205,196,0.2);
  border-left: 4px solid var(--cyan); border-radius: 0 var(--radius-md) var(--radius-md) 0;
  padding: 14px 18px; margin-bottom: 20px;
}
.v2-qs-icon { font-size: 1.3rem; flex-shrink: 0; line-height: 1; margin-top: 2px; }
.v2-qs-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--cyan); margin-bottom: 5px;
}
.v2-qs-text { font-size: 0.88rem; color: var(--text-primary); line-height: 1.65; }

.v2-try-this {
  background: var(--cyan-soft); border: 1px solid rgba(78,205,196,0.2);
  border-left: 4px solid var(--cyan); border-radius: 0 var(--radius-md) var(--radius-md) 0;
  padding: 12px 18px; margin: 16px 0;
}
.v2-try-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--cyan); margin-bottom: 6px;
}
.v2-try-this p { font-size: 0.88rem; color: var(--text-primary); margin: 3px 0 0; }

.v2-callout {
  padding: 12px 16px; border-radius: 0 var(--radius-md) var(--radius-md) 0;
  margin: 12px 0; font-size: 0.87rem; line-height: 1.65; color: var(--text-secondary);
}
.v2-callout p { margin: 0; font-size: 0.87rem; }
.v2-callout p + p { margin-top: 6px; }
.v2-callout.info    { background: var(--blue-soft);   border-left: 3px solid var(--blue); }
.v2-callout.warning { background: var(--accent-soft); border-left: 3px solid var(--accent); }
.v2-callout.danger  { background: var(--red-soft);    border-left: 3px solid var(--red); }
.v2-callout.success { background: var(--green-soft);  border-left: 3px solid var(--green); }

.v2-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 12px 0; }
.v2-col { padding: 14px; border-radius: var(--radius-md); border: 1px solid var(--border); }
.v2-col.good    { background: var(--green-soft); border-color: rgba(94,194,105,0.2); }
.v2-col.bad     { background: var(--red-soft);   border-color: rgba(232,92,92,0.15); }
.v2-col.neutral { background: var(--bg-elevated); }
.v2-col.info    { background: var(--blue-soft);  border-color: rgba(111,163,247,0.2); }
.v2-col-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 9px;
}
.v2-col.good .v2-col-label    { color: var(--green); }
.v2-col.bad .v2-col-label     { color: var(--red); }
.v2-col.neutral .v2-col-label { color: var(--accent); }
.v2-col.info .v2-col-label    { color: var(--blue); }

.v2-context-grid { display: grid; gap: 10px; margin: 10px 0; }
.v2-context-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-md); padding: 14px 18px; transition: border-color 0.2s;
}
.v2-context-card:hover { border-color: rgba(176,140,245,0.4); }
.v2-context-header { display: flex; align-items: center; gap: 9px; margin-bottom: 7px; }
.v2-context-tag {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; font-weight: 700;
  color: var(--purple); background: var(--purple-soft); padding: 2px 9px; border-radius: 4px;
}
.v2-context-title { font-size: 0.86rem; font-weight: 600; color: var(--text-primary); }
.v2-context-desc { font-size: 0.83rem; color: var(--text-secondary); margin-bottom: 9px; line-height: 1.6; }
.v2-context-meta {
  display: grid; grid-template-columns: 80px 1fr; gap: 5px 8px;
  font-size: 0.81rem; padding-top: 9px; border-top: 1px solid var(--border-subtle);
}
.v2-context-key {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.58rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px; color: var(--text-dim); padding-top: 2px;
}
.v2-context-val { color: var(--text-secondary); line-height: 1.5; font-size: 0.83rem; }

.v2-pattern-card {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: var(--radius-md); padding: 16px 20px; margin: 10px 0;
}
.v2-pattern-num {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--accent); margin-bottom: 4px;
}
.v2-pattern-title { font-size: 0.98rem; font-weight: 600; color: var(--text-primary); margin-bottom: 10px; }
.v2-pattern-section { margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--border-subtle); }
.v2-pattern-section-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.57rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); margin-bottom: 5px;
}

.v2-code-wrap { display: flex; flex-direction: column; margin: 10px 0; }
.v2-code-wrap .code-block { margin: 0; }
.v2-code-wrap pre { white-space: pre-wrap; word-break: break-word; overflow-wrap: break-word; }
.v2-copy-btn {
  align-self: flex-end; margin-bottom: 4px;
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted);
  background: var(--bg-elevated); border: 1px solid var(--border);
  padding: 3px 8px; border-radius: 4px; cursor: pointer; transition: all 0.2s;
}
.v2-copy-btn:hover  { color: var(--accent); border-color: var(--accent); }
.v2-copy-btn.copied { color: var(--green);  border-color: var(--green); }

.v2-transcript {
  background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: var(--radius-md); margin: 10px 0; overflow: hidden;
}
.v2-transcript-header {
  padding: 8px 14px; background: var(--bg-elevated); border-bottom: 1px solid var(--border);
  font-family: 'IBM Plex Mono', monospace; font-size: 0.58rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 2px; color: var(--text-dim);
}
.v2-turn {
  display: grid; grid-template-columns: 72px 1fr; gap: 10px;
  padding: 10px 14px; border-bottom: 1px solid var(--border-subtle);
}
.v2-turn:last-child { border-bottom: none; }
.v2-turn-role {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 700;
  text-transform: uppercase; letter-spacing: 1px; padding-top: 2px;
}
.v2-turn-role.user   { color: var(--blue); }
.v2-turn-role.agent  { color: var(--purple); }
.v2-turn-role.system { color: var(--green); }
.v2-turn-text { font-size: 0.84rem; color: var(--text-secondary); line-height: 1.65; }
.v2-turn-text code { font-size: 0.8em; }

.v2-decision-grid { display: grid; gap: 8px; margin: 10px 0; }
.v2-decision-row {
  display: grid; grid-template-columns: 1fr auto; gap: 14px;
  padding: 10px 14px; background: var(--bg-elevated);
  border-radius: var(--radius-sm); border: 1px solid var(--border); align-items: center;
}
.v2-decision-when { font-size: 0.85rem; color: var(--text-secondary); line-height: 1.4; }
.v2-decision-use  { font-family: 'IBM Plex Mono', monospace; font-size: 0.75rem; font-weight: 700; color: var(--accent); white-space: nowrap; }

.v2-self-check {
  background: var(--bg-secondary); border: 1px solid var(--border);
  border-radius: var(--radius-md); padding: 18px 22px; margin: 16px 0;
}
.v2-self-check-title { font-size: 1.0rem; font-weight: 600; color: var(--text-primary); margin-bottom: 3px; }
.v2-self-check-sub   { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 14px; }
.v2-check-list { list-style: none; display: grid; gap: 8px; padding: 0; margin: 0; }
.v2-check-item { display: flex; align-items: flex-start; gap: 9px; font-size: 0.89rem; color: var(--text-secondary); line-height: 1.5; }
.v2-check-item::before { content: none !important; }
.v2-checkbox {
  width: 17px; height: 17px; border: 2px solid var(--border); border-radius: 3px;
  flex-shrink: 0; margin-top: 2px; cursor: pointer; transition: all 0.15s;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem; font-weight: 700; color: transparent;
}
.v2-checkbox:hover  { border-color: var(--green); }
.v2-checkbox.checked { background: var(--green); border-color: var(--green); color: white; }

.v2-progressive-marker {
  display: inline-flex; align-items: center; gap: 5px;
  font-family: 'IBM Plex Mono', monospace; font-size: 0.6rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 1.5px; color: var(--purple);
  background: var(--purple-soft); border: 1px solid rgba(176,140,245,0.2);
  padding: 2px 9px; border-radius: 4px; margin-bottom: 5px;
}

a.v2-cross-link {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.78em; font-weight: 600;
  color: var(--accent); text-decoration: none; border-bottom: 1px dotted var(--accent);
}
a.v2-cross-link:hover { border-bottom-style: solid; }

/* Row Card — compact ERA/timeline list (Option G: frosted glass + amber title) */
.v2-card-list { display: grid; gap: 8px; margin: 14px 0; }
.v2-row-card {
  display: grid; grid-template-columns: 100px 1fr; gap: 14px;
  padding: 12px 16px; border-radius: 8px; align-items: center;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.08);
}
.v2-era-badge {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; font-weight: 700;
  color: var(--text-muted); background: var(--bg-secondary);
  padding: 2px 7px; border-radius: 4px; border: 1px solid var(--border-subtle);
  display: inline-block;
}
.v2-era-name { font-size: 0.8rem; font-weight: 700; color: #b07020; margin-top: 6px; }
.v2-era-date { font-size: 0.74rem; color: var(--text-dim); margin-top: 2px; }
.v2-card-body { font-size: 0.84rem; color: var(--text-secondary); line-height: 1.6; }

/* Info Card — tool/spectrum list (Option G: frosted glass + amber tool name) */
.v2-info-card {
  display: grid; grid-template-columns: 160px 1fr; gap: 14px;
  padding: 12px 16px; border-radius: 8px;
  background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.10);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.08);
}
.v2-tool-name { font-size: 0.84rem; font-weight: 700; color: #b07020; }
.v2-tool-mode { font-size: 0.72rem; color: var(--text-muted); margin-top: 3px; font-family: 'IBM Plex Mono', monospace; }

/* Era Card — expanded full-width era detail with example (Option G: frosted glass) */
.v2-era-card {
  padding: 14px 16px; border-radius: 8px;
  background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  box-shadow: 0 4px 20px rgba(0,0,0,0.22), inset 0 1px 0 rgba(255,255,255,0.08);
}
.v2-era-card-header { display: flex; align-items: baseline; gap: 10px; margin-bottom: 8px; }
.v2-era-card .v2-era-name { font-size: 0.92rem; margin-top: 0; }
.v2-era-card .v2-era-date { font-size: 0.75rem; }
.v2-example-box {
  padding: 10px 14px; background: var(--code-bg, #1a1a2e);
  border-radius: 6px; border-left: 3px solid var(--border); margin-top: 10px;
}
.v2-example-label {
  font-size: 0.74rem; font-weight: 700; color: var(--text-muted);
  text-transform: uppercase; letter-spacing: 0.4px; margin-bottom: 5px;
}
.v2-example-text { font-size: 0.83rem; color: var(--text-secondary); line-height: 1.7; }

/* Step List — numbered or arrow sequence steps */
.v2-step-list { display: grid; gap: 6px; margin: 14px 0; }
.v2-step {
  display: grid; grid-template-columns: 32px 1fr; gap: 10px;
  padding: 10px 14px; background: var(--bg-elevated);
  border-radius: 6px; border: 1px solid var(--border);
}
.v2-step-num {
  font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem;
  font-weight: 700; color: var(--accent); padding-top: 1px;
}
.v2-step-title { font-size: 0.9rem; font-weight: 600; margin-bottom: 4px; color: var(--text-primary); }
.v2-step-body { font-size: 0.84rem; color: var(--text-secondary); }

/* ─── Mobile ─── */
@media (max-width: 820px) {
  .guide-sidebar {
    position: fixed; left: -230px; top: 48px; bottom: 0;
    z-index: 200; box-shadow: 4px 0 20px rgba(0,0,0,0.15);
    transition: left 0.25s ease;
  }
  .guide-sidebar.sb-open { left: 0; }
  .sidebar-toggle-btn { display: flex; }
  .guide-topbar-title { display: none; }
  .v2-slide-wrap { padding: 24px 20px 0; }
  .slide-nav { padding: 24px 20px 32px; }
  .v2-two-col { grid-template-columns: 1fr; }
  .v2-context-meta { grid-template-columns: 1fr; }
  .v2-decision-row { grid-template-columns: 1fr; }
  .v2-turn { grid-template-columns: 58px 1fr; }
  .v2-row-card { grid-template-columns: 1fr; }
  .v2-info-card { grid-template-columns: 1fr; }
}
@media (max-width: 520px) {
  .guide-type-badge { display: none; }
  .guide-topbar-num { display: none; }
}

/* ─── Slide deck helpers (used on all consolidated phase decks) ─── */
.title-slide { text-align: center; display: flex; flex-direction: column; justify-content: center; align-items: center; }
.title-slide h1 { font-size: 1.8rem; margin-bottom: 16px; line-height: 1.2; }
.title-slide h1 em { font-style: normal; color: var(--accent); }
.title-slide .title-sub { color: var(--text-secondary); font-size: 1rem; max-width: 520px; margin: 0 auto 28px; line-height: 1.7; text-align: center; }
.title-stats { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
.title-stat { text-align: center; }
.title-stat-val { font-family: 'Source Serif 4', serif; font-size: 1.4rem; font-weight: 700; }
.title-stat-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-dim); margin-top: 3px; }
/* Heading sizes for slide decks — targets bare h1/h2 (not .v2-section-title used in full guides) */
.v2-slide-wrap h1 { font-size: 1.6rem; }
.v2-slide-wrap h2:not(.v2-section-title) { font-size: 1.3rem; }
.slide-sub { color: var(--text-secondary); margin-bottom: 14px; font-size: 0.9rem; }
.slide-img { width: 100%; display: block; margin: 10px auto 8px; border-radius: 12px; }
.slide-svg { width: 100%; display: block; border-radius: 10px; }
.slide-section-label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; color: var(--accent); font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin: 12px 0 6px; }
.prompt-context    { background: rgba(176,112,32,0.15);  border-radius: 3px; padding: 1px 3px; }
.prompt-task       { background: rgba(94,194,105,0.15);  border-radius: 3px; padding: 1px 3px; }
.prompt-format     { background: rgba(111,163,247,0.15); border-radius: 3px; padding: 1px 3px; }
.prompt-constraint { background: rgba(176,140,245,0.15); border-radius: 3px; padding: 1px 3px; }
/* Command reference highlight for inline @command and #command references */
.v2-slide-wrap code { color: #673ab7; background: rgba(103,58,183,0.1); border-radius: 3px; padding: 1px 5px; font-size: 0.85em; font-family: 'IBM Plex Mono', monospace; }
.code-block code { color: inherit; background: transparent; padding: 0; border-radius: 0; font-size: inherit; }
</style>
{% endblock %}

{% block body %}
<div class="guide-shell">

  <!-- Top Bar -->
  <div class="guide-topbar">
    <a href="{{ topicUrl | default('/topics/ai-in-practice-v2/') }}" class="guide-back">← {{ topicName | default('AI in Practice V2') }}</a>
    <span class="topbar-sep">/</span>
    <div class="guide-topbar-title">{{ sessionTitle | default(title) }}</div>
    {% if sessionNumber %}<div class="guide-topbar-num">Session {{ sessionNumber }}</div>{% endif %}
    {% if sessionNumber %}<div class="guide-type-badge">Full Guide</div>{% endif %}
    <button class="sidebar-toggle-btn" onclick="toggleSidebar()">☰ Sections</button>
  </div>

  <!-- Body -->
  <div class="guide-body">

    <!-- Sidebar -->
    <div class="guide-sidebar" id="guide-sidebar">
      <div class="sidebar-head">Guide Sections</div>
      <div class="sidebar-list" id="sidebar-list"></div>
      <div class="sidebar-foot">
        <div class="prog-track"><div class="prog-fill" id="prog-fill"></div></div>
        <div class="prog-label" id="prog-label">Section 1 of —</div>
      </div>
    </div>

    <!-- Page deck -->
    <div class="guide-deck" id="guide-deck">
      {{ content | safe }}
    </div>

  </div>

</div>

<!-- Floating section counter -->
<div class="guide-float-counter" id="float-counter">1 / —</div>
{% endblock %}

{% block scripts %}
<script>
(function () {
  var deck    = document.getElementById('guide-deck');
  var listEl  = document.getElementById('sidebar-list');
  var slides  = Array.from(deck.querySelectorAll('.slide'));
  var total   = slides.length;
  var current = 0;

  /* ── Build sidebar items and inject nav bars ── */
  slides.forEach(function (slide, i) {
    /* Section number badge */
    var numEl = slide.querySelector('.v2-section-num');
    if (numEl) numEl.textContent = String(i + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');

    /* Hide scroll hints — not meaningful in paginated mode */
    var hint = slide.querySelector('.v2-scroll-hint');
    if (hint) hint.style.display = 'none';

    /* Sidebar item */
    var title = slide.dataset.title || ('Section ' + (i + 1));
    var item  = document.createElement('div');
    item.className = 'sb-item';
    item.dataset.idx = i;
    item.innerHTML =
      '<div class="sb-dot"></div>' +
      '<div class="sb-num">' + String(i + 1).padStart(2, '0') + '</div>' +
      '<div class="sb-label">' + title + '</div>';
    item.addEventListener('click', function () { goTo(i); closeSidebar(); });
    listEl.appendChild(item);

    /* Bottom navigation bar */
    var nav     = document.createElement('div');
    nav.className = 'slide-nav';

    var prevBtn = document.createElement('button');
    prevBtn.className = 'slide-nav-btn prev-btn';
    prevBtn.textContent = '← Previous';
    if (i === 0) prevBtn.disabled = true;
    prevBtn.addEventListener('click', function () { goTo(current - 1); });

    var info = document.createElement('span');
    info.className = 'slide-nav-info';
    info.textContent = String(i + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');

    var nextBtn = document.createElement('button');
    nextBtn.className = 'slide-nav-btn next-btn';
    nextBtn.textContent = i === total - 1 ? 'Complete ✓' : 'Next →';
    if (i === total - 1) {
      nextBtn.style.background = 'var(--green)';
      nextBtn.style.borderColor = 'var(--green)';
      nextBtn.style.cursor = 'default';
    }
    nextBtn.addEventListener('click', function () { if (i < total - 1) goTo(current + 1); });

    nav.appendChild(prevBtn);
    nav.appendChild(info);
    nav.appendChild(nextBtn);
    slide.appendChild(nav);
  });

  /* ── Navigate to a specific section ── */
  function goTo(i) {
    if (i < 0 || i >= total) return;
    slides[current].classList.remove('is-active', 'is-entering');
    current = i;
    slides[current].classList.add('is-active', 'is-entering');
    deck.scrollTop = 0;
    updateUI();
  }

  /* ── Update sidebar, progress bar, and counter ── */
  function updateUI() {
    var items = Array.from(listEl.querySelectorAll('.sb-item'));
    items.forEach(function (item, j) {
      item.classList.remove('is-active', 'is-done');
      if (j < current)  item.classList.add('is-done');
      if (j === current) item.classList.add('is-active');
    });
    var activeItem = items[current];
    if (activeItem) activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' });

    var pct = Math.round((current + 1) / total * 100);
    document.getElementById('prog-fill').style.width  = pct + '%';
    document.getElementById('prog-label').textContent = 'Section ' + (current + 1) + ' of ' + total;
    document.getElementById('float-counter').textContent = (current + 1) + ' / ' + total;
  }

  /* ── Keyboard navigation ── */
  document.addEventListener('keydown', function (e) {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); goTo(current + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); goTo(current - 1); }
    if (e.key === 'Escape') closeSidebar();
  });

  /* ── Sidebar toggle (mobile) ── */
  window.toggleSidebar = function () {
    document.getElementById('guide-sidebar').classList.toggle('sb-open');
  };
  function closeSidebar() {
    document.getElementById('guide-sidebar').classList.remove('sb-open');
  }

  /* ── Copy buttons ── */
  deck.querySelectorAll('.v2-code-wrap').forEach(function (wrap) {
    var btn = document.createElement('button');
    btn.className = 'v2-copy-btn';
    btn.textContent = 'Copy';
    wrap.insertBefore(btn, wrap.firstChild);
    btn.addEventListener('click', function () {
      var pre = wrap.querySelector('pre');
      if (!pre) return;
      navigator.clipboard.writeText(pre.innerText).then(function () {
        btn.textContent = 'Copied!'; btn.classList.add('copied');
        setTimeout(function () { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
      });
    });
  });

  /* ── Checkboxes ── */
  deck.querySelectorAll('.v2-checkbox').forEach(function (box) {
    box.addEventListener('click', function () {
      box.classList.toggle('checked');
      box.textContent = box.classList.contains('checked') ? '✓' : '';
    });
  });

  /* ── Init: show first slide immediately, no animation ── */
  slides[0].classList.add('is-active');
  deck.classList.add('deck-ready');
  updateUI();
})();
</script>
{% endblock %}
